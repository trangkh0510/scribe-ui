# === LLM config (MaaS GreenNode AI Platform) ===
# Điền key/model THẬT của bạn. KHÔNG commit file .env thật (đã nằm trong .dockerignore).
LLM_API_KEY=<your-maas-api-key>
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
# LLM_MODEL: model chain dùng cho phân tích (Route A) và cho bước làm sạch qua /api/chat.
LLM_MODEL=qwen/qwen3-5-27b,qwen/qwen3.6-27b

# === Rate governor (giới hạn theo per-(account, model) của MaaS) ===
# LLM_RPM_DEFAULT: requests-per-minute cho model không có giới hạn riêng bên dưới.
LLM_RPM_DEFAULT=6
# LLM_RPM_LIMITS: map model -> RPM (chỉnh theo quota đo được).
# LLM_RPM_LIMITS={"qwen/qwen3-5-27b": 6, "qwen/qwen3.6-27b": 6}
